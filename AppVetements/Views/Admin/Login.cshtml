@{
    ViewData["Title"] = "Admin - Connexion";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card border-0 shadow p-4" style="border-radius:20px;">
            <div class="text-center mb-4">
                <i class="bi bi-shield-lock-fill" style="font-size:3rem; color:#1a1a2e;"></i>
                <h4 class="fw-bold mt-2">Administration</h4>
            </div>
            @if (ViewBag.Erreur != null)
            {
                <div class="alert alert-danger">@ViewBag.Erreur</div>
            }
            <form method="post">
                <div class="mb-3">
                    <label class="fw-bold">Login</label>
                    <input type="text" name="login" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="fw-bold">Mot de passe</label>
                    <input type="password" name="motDePasse" class="form-control" required />
                </div>
                <button type="submit" class="btn w-100 fw-bold text-white"
                        style="background:#1a1a2e;">
                    <i class="bi bi-box-arrow-in-right"></i> Se connecter
                </button>
            </form>
        </div>
    </div>
</div>