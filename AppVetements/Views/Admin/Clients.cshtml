@model List<AppVetements.Models.Client>
@{
    ViewData["Title"] = "Gestion Clients";
}
<a href="/Admin/Index" class="btn btn-dark mb-3">
    <i class="bi bi-arrow-left"></i> Retour Dashboard
</a>
<div class="container-fluid my-4">
    <h2 class="fw-bold mb-4">
        <i class="bi bi-people-fill"></i> Gestion des Clients
    </h2>

    <div class="card border-0 shadow-sm p-4" style="border-radius:15px;">
        <table class="table table-hover">
            <thead style="background:#1a1a2e; color:white;">
                <tr>
                    <th>#</th>
                    <th>Nom</th>
                    <th>Email</th>
                    <th>Téléphone</th>
                    <th>Adresse</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var client in Model)
                {
                    <tr>
                        <td>@client.ID</td>
                        <td>@client.NomComplet</td>
                        <td>@client.Email</td>
                        <td>@client.Telephone</td>
                        <td>@client.Adresse</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>