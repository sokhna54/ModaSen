<!-- AVANTAGES -->
<div style="background:#f8f9fa;" class="py-5">
    <div class="container">
        <div class="row text-center">
            <div class="col-md-4 mb-4">
                <div style="font-size:3rem;"><i class="bi bi-truck" style="font-size:3rem; color:#f0a500;"></i></div>
                <h5 class="fw-bold mt-2">Livraison Rapide</h5>
                <p class="text-muted">Partout au Sénégal en 24-48h</p>
            </div>
            <div class="col-md-4 mb-4">
                <div style="font-size:3rem;"><i class="bi bi-patch-check-fill" style="font-size:3rem; color:#f0a500;"></i></div>
                <h5 class="fw-bold mt-2">Qualité Garantie</h5>
                <p class="text-muted">Tous nos produits sont vérifiés</p>
            </div>
            <div class="col-md-4 mb-4">
                <div style="font-size:3rem;"><i class="bi bi-shield-lock-fill" style="font-size:3rem; color:#f0a500;"></i></div>
                <h5 class="fw-bold mt-2">Paiement Sécurisé</h5>
                <p class="text-muted">Wave, Orange Money acceptés</p>
            </div>
        </div>
    </div>
</div>
<!-- PROMOTIONS (affichée seulement s'il y a des promos) -->
@if (ViewBag.ProduitsEnPromo != null && ViewBag.ProduitsEnPromo.Count > 0)
{
    <div class="container my-5">
        <div class="text-center mb-4">
            <h2 class="fw-bold">🔥 Promotions en cours</h2>
            <p class="text-muted">Profitez de nos meilleures offres</p>
        </div>
        <div class="row">
            @foreach (var p in ViewBag.ProduitsEnPromo)
            {
                <div class="col-md-3 mb-4">
                    <div class="card border-0 shadow-sm h-100"
                         style="border-radius:15px; overflow:hidden;">
                        <!-- BADGE PROMO -->
                        <div style="position:relative;">
                            @if (!string.IsNullOrEmpty(p.ImageProduit))
                            {
                                <img src="@p.ImageProduit"
                                     style="width:100%; height:220px; object-fit:cover;" />
                            }
                            <span style="position:absolute; top:10px; left:10px;
                                background:#e53935; color:white; padding:5px 12px;
                                border-radius:10px; font-weight:bold;">
                                -@p.Remise%
                            </span>
                        </div>
                        <div class="card-body">
                            <h6 class="fw-bold">@p.NomProduit</h6>
                            <p class="text-muted text-decoration-line-through small">
                                @p.Prix.ToString("N0") FCFA
                            </p>
                            <h5 style="color:#e53935;" class="fw-bold">
                                @p.PrixPromo.ToString("N0") FCFA
                            </h5>
                            <a href="/Boutique/Detail/@p.ID"
                                   class="btn btn-warning w-100 fw-bold mt-2">
                                Voir le produit
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="text-center mt-3">
            <a href="/Boutique/Index" class="btn btn-outline-danger px-5 fw-bold">
                Voir toutes les promos
            </a>
        </div>
    </div>
}
