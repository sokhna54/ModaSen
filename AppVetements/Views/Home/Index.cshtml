                    <div class="text-center p-3">
                        <h5 class="fw-bold">Enfant</h5>
                        <p class="text-muted small">Tenues enfants...</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3 mb-4">
            <a href="/Boutique/Index?categorie=4" style="text-decoration:none;">
                <div class="card border-0 shadow-sm overflow-hidden" style="border-radius:20px; transition:0.3s;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
