<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ModaSen</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    
    <!-- ✅ Bootstrap Icons (remplace Font Awesome) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
    
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', sans-serif; }
        .navbar { background: #1a1a2e !important; }
        .navbar-brand { color: #f0a500 !important; font-size: 1.8rem; font-weight: bold; }
        .nav-link { color: white !important; font-weight: 500; }
        .nav-link:hover { color: #f0a500 !important; }
        .btn-panier { background: #f0a500; color: white; border-radius: 20px; }
        .btn-panier:hover { background: #d4920a; color: white; }
    </style>
</head>
<body>

<!-- NAVBAR -->
<!-- NAVBAR -->
<nav class="navbar navbar-expand-lg sticky-top shadow">
    <div class="container">
        <a class="navbar-brand" href="/">👗 ModaSen</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav me-auto">
                <li class="nav-item"><a class="nav-link" href="/"><i class="bi bi-house-fill"></i> Accueil</a></li>
                <li class="nav-item"><a class="nav-link" href="/Boutique/Index"><i class="bi bi-bag-fill"></i> Boutique</a></li>
            </ul>
            <ul class="navbar-nav ms-auto align-items-center">

                @if (Context.Session.GetString("AdminNom") != null)
                {
                    <!-- ADMIN CONNECTE -->
                    <li class="nav-item">
                        <span class="nav-link text-warning">
                            <i class="bi bi-shield-fill"></i> Admin
                        </span>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Admin/Index">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-danger" href="/Admin/Logout">
                            <i class="bi bi-box-arrow-right"></i> Déconnexion
                        </a>
                    </li>
                }
                else if (Context.Session.GetString("ClientNom") != null)
                {
                    <!-- CLIENT CONNECTE -->
                    <li class="nav-item">
                        <span class="nav-link text-warning">
                            <i class="bi bi-person-fill"></i> @Context.Session.GetString("ClientNom")
                        </span>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Commande/MesCommandes">
                            <i class="bi bi-list-ul"></i> Mes commandes
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link btn btn-panier px-3 me-2" href="/Panier/Index">
                            <i class="bi bi-cart-fill"></i> Panier
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-danger" href="/Auth/Logout">
                            <i class="bi bi-box-arrow-right"></i> Déconnexion
                        </a>
                    </li>
                }
                else
                {
                    <!-- NON CONNECTE -->
                    <li class="nav-item">
                        <a class="nav-link" href="/Auth/Login">
                            <i class="bi bi-lock-fill"></i> Connexion
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-warning ms-2 px-3" href="/Auth/Register">
                            S'inscrire
                        </a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>
@RenderBody()

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<!-- BOUTON WHATSAPP FIXE -->
<a href="https://wa.me/221775114243" target="_blank"
   style="position:fixed; bottom:30px; right:30px; z-index:9999;
          background:#25D366; color:white; width:60px; height:60px;
          border-radius:50%; display:flex; align-items:center;
          justify-content:center; box-shadow:0 4px 15px rgba(0,0,0,0.3);
          text-decoration:none; font-size:1.8rem;">
    <i class="bi bi-whatsapp"></i>
</a>
</body>
</html>