@model List<AppVetements.Models.Categorie>
<a href="/Admin/Index" class="btn btn-dark mb-3">
    <i class="bi bi-arrow-left"></i> Retour Dashboard
</a>
<h2>Liste des Catégories</h2>
<a href="/Categorie/Ajouter" class="btn btn-success mb-3">+ Ajouter</a>

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Nom Catégorie</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.ID</td>
                <td>@c.NomCategorie</td>
                <td>
                    <a href="/Categorie/Modifier/@c.ID" class="btn btn-warning btn-sm">✏️ Modifier</a>
                    <a href="/Categorie/Supprimer/@c.ID" class="btn btn-danger btn-sm"
                       onclick="return confirm('Supprimer cette catégorie ?')">🗑️ Supprimer</a>
                </td>
            </tr>
        }
    </tbody>
</table>