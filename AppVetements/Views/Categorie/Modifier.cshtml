@model AppVetements.Models.Categorie

<h2>Modifier la Catégorie</h2>

<form method="post">
    <input asp-for="ID" type="hidden" />
    <div class="mb-3">
        <label>Nom de la catégorie</label>
        <input asp-for="NomCategorie" class="form-control" required />
    </div>
    <button type="submit" class="btn btn-warning">Modifier</button>
    <a href="/Categorie/Index" class="btn btn-secondary">Annuler</a>
</form>