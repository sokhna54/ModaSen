@model AppVetements.Models.Commande
@{
    ViewData["Title"] = "Commande confirmée";
}

<div class="container my-5 text-center">
    <div class="card border-0 shadow-sm p-5 mx-auto" style="border-radius:20px; max-width:600px;">
        <div style="font-size:5rem; color:#28a745;">
            <i class="bi bi-check-circle-fill"></i>
        </div>
        <h2 class="fw-bold mt-3">Commande confirmée !</h2>
        <p class="text-muted">Merci <strong>@Model.Client.NomComplet</strong> pour votre commande.</p>

        <div class="card bg-light border-0 p-3 my-3" style="border-radius:15px;">
            <div class="d-flex justify-content-between mb-2">
                <span class="text-muted">Numéro de commande</span>
                <strong>#@Model.ID</strong>
            </div>
            <div class="d-flex justify-content-between mb-2">
                <span class="text-muted">Date</span>
                <strong>@Model.DateCommande.ToString("dd/MM/yyyy HH:mm")</strong>
            </div>
            <div class="d-flex justify-content-between mb-2">
                <span class="text-muted">Statut</span>
                <span class="badge bg-warning text-dark">@Model.Statut</span>
            </div>
            <div class="d-flex justify-content-between">
                <span class="text-muted">Total</span>
                <strong style="color:#f0a500;">@Model.Total.ToString("N0") FCFA</strong>
            </div>
        </div>

        <h6 class="fw-bold mt-3">Articles commandés :</h6>
        @foreach (var ligne in Model.LignesCommande)
        {
            <div class="d-flex justify-content-between py-2 border-bottom">
                <span>@ligne.Produit.NomProduit x@ligne.Quantite</span>
                <span>@((ligne.PrixUnitaire * ligne.Quantite).ToString("N0")) FCFA</span>
            </div>
        }

        <div class="mt-4 d-flex gap-3 justify-content-center">
            <a href="/Commande/MesCommandes" class="btn btn-outline-dark px-4">
                <i class="bi bi-list-ul"></i> Mes commandes
            </a>
            <a href="/Boutique/Index" class="btn btn-warning px-4 fw-bold">
                <i class="bi bi-bag-fill"></i> Continuer les achats
            </a>
            <a href="/Commande/Facture/@Model.ID"
                   class="btn btn-outline-dark mt-3" target="_blank">
                <i class="bi bi-file-earmark-pdf-fill text-danger"></i>
                Télécharger ma facture
            </a>
        </div>
    </div>
</div>