@model List<AppVetements.Models.Commande>
@{
    ViewData["Title"] = "Mes Commandes";
}

<div class="container my-5">
    <h2 class="fw-bold mb-4">
        <i class="bi bi-list-ul"></i> Mes Commandes
    </h2>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-bag-x" style="font-size:5rem; color:#ccc;"></i>
            <h4 class="text-muted mt-3">Aucune commande</h4>
            <a href="/Boutique/Index" class="btn btn-warning mt-3 px-5">
                Commencer les achats
            </a>
        </div>
    }
    else
    {
        @foreach (var commande in Model)
        {
            <div class="card border-0 shadow-sm mb-4 p-4" style="border-radius:15px;">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <h6 class="fw-bold">Commande #@commande.ID</h6>
                        <small class="text-muted">@commande.DateCommande.ToString("dd/MM/yyyy HH:mm")</small>
                    </div>
                    @if (commande.Statut == "En attente")
                    {
                        <span class="badge bg-warning text-dark p-2">⏳ @commande.Statut</span>
                    }
                    else if (commande.Statut == "En livraison")
                    {
                        <span class="badge bg-info p-2">🚚 @commande.Statut</span>
                    }
                    else if (commande.Statut == "Livré")
                    {
                        <span class="badge bg-success p-2">✅ @commande.Statut</span>
                    }
                </div>

                <!-- SUIVI LIVRAISON -->
                <div class="mb-4">
                    <div class="d-flex justify-content-between align-items-center position-relative">
                        <!-- LIGNE -->
                        <div style="position:absolute; top:20px; left:10%; right:10%; height:4px; background:#e0e0e0; z-index:0;">
                            <div style="height:100%; background:#f0a500; width:
                                @(commande.Statut == "En attente" ? "0%" :
                                                                   commande.Statut == "En livraison" ? "50%" : "100%");
                                transition:0.5s;">
                            </div>
                        </div>

                        <!-- ETAPE 1 -->
                        <div class="text-center" style="z-index:1; width:33%;">
                            <div style="width:40px; height:40px; border-radius:50%; margin:auto;
                                background:@(commande.Statut == "En attente" || commande.Statut == "En livraison" || commande.Statut == "Livré" ? "#f0a500" : "#e0e0e0");
                                display:flex; align-items:center; justify-content:center;">
                                <i class="bi bi-check text-white fw-bold"></i>
                            </div>
                            <p class="small fw-bold mt-2">Commande passée</p>
                        </div>

                        <!-- ETAPE 2 -->
                        <div class="text-center" style="z-index:1; width:33%;">
                            <div style="width:40px; height:40px; border-radius:50%; margin:auto;
                                background:@(commande.Statut == "En livraison" || commande.Statut == "Livré" ? "#f0a500" : "#e0e0e0");
                                display:flex; align-items:center; justify-content:center;">
                                <i class="bi bi-truck text-white fw-bold"></i>
                            </div>
                            <p class="small fw-bold mt-2">En livraison</p>
                        </div>

                        <!-- ETAPE 3 -->
                        <div class="text-center" style="z-index:1; width:33%;">
                            <div style="width:40px; height:40px; border-radius:50%; margin:auto;
                                background:@(commande.Statut == "Livré" ? "#f0a500" : "#e0e0e0");
                                display:flex; align-items:center; justify-content:center;">
                                <i class="bi bi-house text-white fw-bold"></i>
                            </div>
                            <p class="small fw-bold mt-2">Livré</p>
                        </div>
                    </div>
                </div>

                <!-- ARTICLES -->
                @foreach (var ligne in commande.LignesCommande)
                {
                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span>@ligne.Produit.NomProduit x@ligne.Quantite</span>
                        <span>@((ligne.PrixUnitaire * ligne.Quantite).ToString("N0")) FCFA</span>
                    </div>
                }

                <div class="d-flex justify-content-between mt-3">
                    <strong>Total</strong>
                    <strong style="color:#f0a500;">@commande.Total.ToString("N0") FCFA</strong>
                </div>
                <!-- BOUTON TÉLÉCHARGER FACTURE -->
                <div class="text-end mt-3">
                    <a href="/Commande/Facture/@commande.ID"
                           class="btn btn-outline-dark btn-sm" target="_blank">
                        <i class="bi bi-file-earmark-pdf-fill text-danger"></i>
                        Télécharger la facture
                    </a>
                </div>
            </div>
        }
    }
</div>